# IGNORE EVERYTHING enable what is needed.
/*
wp-config.php
!DEVIN.md
!.devin
!.gitignore

!/assets
/assets/*
!/assets/debug.log
# /wp-content/upgrade
# /wp-content/uploads
# /wp-content/wflogs

!/assets/cache
/assets/cache/*
!/assets/cache/log/

!/assets/mu-plugins/
/assets/mu-plugins/*
!/assets/mu-plugins/sam_tools.php
!/assets/mu-plugins/sam

# LIST ALL PLUGIN DIRS SO WE KNOW WHAT IS INSTALLED
!/assets/plugins/
/assets/plugins/*
!/assets/plugins/freedom-index
/assets/plugins/freedom-index/vendor/*

# THEMES
!/assets/themes
/assets/themes/*
!/assets/themes/votetruth

# *DEV*
*COPY*
*X.*
*x.*

# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip
*.tar.gz

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db